<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_player_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:elevation="6dp"
    android:visibility="gone"
    android:paddingHorizontal="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <!-- 歌曲名 -->
    <TextView
        android:id="@+id/tv_playing_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:ellipsize="end"
        android:singleLine="true"
        android:gravity="center" />

    <!-- 进度条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

        <SeekBar
            android:id="@+id/seekbar_player"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:max="1000"
            android:progress="0"
            android:progressTint="?attr/colorPrimary"
            android:thumbTint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tv_total_time"
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center" />
    </LinearLayout>

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <!-- 静音按钮 -->
        <LinearLayout
            android:id="@+id/btn_mute"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">

            <TextView
                android:id="@+id/tv_mute_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- 播放/暂停 -->
        <LinearLayout
            android:id="@+id/btn_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_icon_button"
            android:layout_marginHorizontal="16dp">

            <TextView
                android:id="@+id/tv_play_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="20sp"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>

        <!-- 关闭 -->
        <LinearLayout
            android:id="@+id/btn_close_player"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="18sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
