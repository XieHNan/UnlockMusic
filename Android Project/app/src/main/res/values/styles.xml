<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ 父样式锚点（子样式隐式继承需要，parent="" 切断上层隐式 parent） ============ -->
    <style name="TextAppearance.UMusic" parent="" />
    <style name="Widget.UMusic" parent="" />
    <style name="Widget.UMusic.Button" parent="" />

    <!-- ============ 文字外观 ============ -->
    <style name="TextAppearance.UMusic.LargeTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.UMusic.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.UMusic.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_regular</item>
    </style>
    <style name="TextAppearance.UMusic.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.UMusic.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ============ 卡片容器（圆角白底 + 细描边 + 微阴影） ============ -->
    <style name="Widget.UMusic.Card">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- 列表项卡片（内边距更紧凑） -->
    <style name="Widget.UMusic.Card.Item">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <!-- ============ 按钮（继承 Material3，自动用 colorPrimary） ============ -->
    <style name="Widget.UMusic.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
    <style name="Widget.UMusic.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/border_color</item>
    </style>
    <style name="Widget.UMusic.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">44dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- 圆形图标按钮（播放/保存） -->
    <style name="Widget.UMusic.IconButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_icon_button</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- ============ 调色板色块 ============ -->
    <style name="Widget.UMusic.Swatch">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_swatch_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
    <style name="Widget.UMusic.SwatchColor">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:background">@drawable/bg_swatch_fill</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <!-- 设置项分区标题 -->
    <style name="TextAppearance.UMusic.SectionTitle">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 设置对话框圆角背景 -->
    <style name="Theme.UMusic.SettingsDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/bg_dialog</item>
    </style>

</resources>
